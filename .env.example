# Shared password for the admin dashboard login gate
ADMIN_DASHBOARD_PASSWORD=

# Random 32+ char secret used to sign the session cookie (e.g. `openssl rand -base64 32`)
SESSION_SECRET=

# PostHog Personal API Key, scoped to "Query Read" only
POSTHOG_PERSONAL_API_KEY=
POSTHOG_PROJECT_ID=
POSTHOG_HOST=https://us.i.posthog.com

# App Store rating summary (numeric App Store ID, from the app's App Store URL)
APPLE_APP_ID=
APPLE_STORE_COUNTRY=kr

# App Store download counts, via the Analytics Reports API (needs the "Sales
# and Reports" role, not Finance — generate the key as the Account Holder
# since the first ONGOING report request needs Admin access once).
# App Store Connect > Users and Access > Integrations > App Store Connect API
APPLE_API_KEY_ID=
APPLE_API_ISSUER_ID=
APPLE_API_PRIVATE_KEY=

# Google Play reviews (service account JSON as a single-line string, granted
# read access in Play Console > Setup > API access)
GOOGLE_PLAY_PACKAGE_NAME=
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=

# Google Play aggregate stats (total rating, installs, star distribution).
# These come from the monthly CSV reports Play Console writes to a Cloud
# Storage bucket, NOT from the Play Developer API — the reviews API only
# returns text reviews from the last week. The service account needs the
# ACCOUNT-level permission "View app information and download bulk reports
# (read-only)" (Users and permissions > Account permissions tab).
# Bucket name is on Play Console > Download reports (gs://pubsite_prod_...)
GOOGLE_PLAY_REPORTS_BUCKET=
