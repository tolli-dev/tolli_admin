# Shared password for the admin dashboard login gate
ADMIN_DASHBOARD_PASSWORD=

# Random 32+ char secret used to sign the session cookie (e.g. `openssl rand -base64 32`)
SESSION_SECRET=

# PostHog Personal API Key, scoped to "Query Read" only
POSTHOG_PERSONAL_API_KEY=
POSTHOG_PROJECT_ID=
POSTHOG_HOST=https://us.i.posthog.com

# App Store rating summary (numeric App Store ID, from the app's App Store URL)
APPLE_APP_ID=
APPLE_STORE_COUNTRY=kr

# Google Play reviews (service account JSON as a single-line string, granted
# read access in Play Console > Setup > API access)
GOOGLE_PLAY_PACKAGE_NAME=
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=
